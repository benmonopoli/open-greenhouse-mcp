# Required: at least one of these
GREENHOUSE_API_KEY=your-harvest-api-key
# GREENHOUSE_BOARD_TOKEN=your-board-url-slug

# Optional: user-scoped permissions — derive profile automatically from user's Greenhouse role
# When set, the server fetches the user's permissions at startup and:
#   - site_admin=true → full profile (all tools, all jobs)
#   - has job permissions → recruiter profile (writes scoped to permitted jobs only)
#   - no permissions → read-only profile
#   - disabled user → server refuses to start
# Also automatically sets On-Behalf-Of header for audit trail.
# GREENHOUSE_USER_ID=your-greenhouse-user-id

# Optional: included in On-Behalf-Of header on all write operations (audit trail)
# Ignored when GREENHOUSE_USER_ID is set (On-Behalf-Of is derived automatically).
# GREENHOUSE_ON_BEHALF_OF=your-greenhouse-user-id

# Optional: tool profile — full (default), recruiter, or read-only
# Ignored when GREENHOUSE_USER_ID is set (profile is derived automatically).
# GREENHOUSE_TOOL_PROFILE=recruiter

# Optional: shorthand for GREENHOUSE_TOOL_PROFILE=read-only
# GREENHOUSE_READ_ONLY=true

# Optional: structured JSON logging (debug, info, warning, error)
# GREENHOUSE_LOG_LEVEL=info
# GREENHOUSE_LOG_FILE=/var/log/greenhouse-mcp.log

# Optional: webhook receiver settings
# GREENHOUSE_WEBHOOK_SECRET=your-webhook-secret-key
# WEBHOOK_DB_PATH=~/.open-greenhouse-mcp/webhooks.db
# PORT=8080
