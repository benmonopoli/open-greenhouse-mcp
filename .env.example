# Required: at least one of these
GREENHOUSE_API_KEY=your-harvest-api-key
# GREENHOUSE_BOARD_TOKEN=your-board-url-slug

# Optional: included in On-Behalf-Of header on all write operations (audit trail)
# GREENHOUSE_ON_BEHALF_OF=your-greenhouse-user-id

# Optional: only register read/query tools (skips all create/update/delete tools)
# GREENHOUSE_READ_ONLY=true

# Optional: webhook receiver settings
# GREENHOUSE_WEBHOOK_SECRET=your-webhook-secret-key
# WEBHOOK_DB_PATH=~/.open-greenhouse-mcp/webhooks.db
# PORT=8080
